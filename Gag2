local shopBuyLoopIds = {}

function getShopStockCount(c, itemName)
    local stockItem = c.Stock and c.Stock:FindFirstChild(itemName)
    return math.max(0, math.floor(tonumber(stockItem and stockItem.Value) or 0))
end
function waitShopStockChange(c, itemName, previousStock, timeout)
    local timeoutAt = os.clock() + (timeout or 1.25)
    while os.clock() < timeoutAt do
        if getShopStockCount(c, itemName) < previousStock then return true end
        task.wait(0.1)
    end
    return false
end
function getBuyTargets(c, allStock)
    local list = {}
    if c.UseRarity and #st.selectedRarity > 0 then
        for _, stockItem in ipairs(c.Stock:GetChildren()) do
            local rarity = getSeedRarity(stockItem.Name)
            if rarity and table.find(st.selectedRarity, rarity) then
                table.insert(list, { Name = stockItem.Name, Price = c.Price(stockItem.Name) })
            end
        end
    elseif #(st[c.Selected] or {}) > 0 then
        for _, name in ipairs(st[c.Selected] or {}) do
            table.insert(list, { Name = name, Price = c.Price(name) })
        end
    elseif allStock then
        for _, stockItem in ipairs(c.Stock:GetChildren()) do
            if getShopStockCount(c, stockItem.Name) > 0 then
                table.insert(list, { Name = stockItem.Name, Price = c.Price(stockItem.Name) })
            end
        end
    end
    table.sort(list, function(a, b) return a.Price > b.Price end)
    return list
end
function purchaseShopItem(c, itemName)
    local networking = modules.networking
    local ok = false
    if c.Packet == "purchaseseed" and networking and networking.SeedShop and networking.SeedShop.PurchaseSeed then
        ok = pcall(function() networking.SeedShop.PurchaseSeed:Fire(itemName) end)
    elseif c.Packet == "purchasegear" and networking and networking.GearShop and networking.GearShop.PurchaseGear then
        ok = pcall(function() networking.GearShop.PurchaseGear:Fire(itemName) end)
    end
    if ok then return true end
    return firePacketByName(c.Packet, itemName) == true
end
function buyShopLoop(c, toggleKey, allStock, loopId)
    while st[toggleKey] and shopBuyLoopIds[toggleKey] == loopId do
        for _, item in ipairs(getBuyTargets(c, allStock)) do
            if not st[toggleKey] or shopBuyLoopIds[toggleKey] ~= loopId then break end
            local stock = getShopStockCount(c, item.Name)
            local inputAmount = math.max(1, math.floor(tonumber(st[c.Amount]) or 1))
            local amount = allStock and stock or math.min(inputAmount, stock)
            for _ = 1, amount do
                if not st[toggleKey] or shopBuyLoopIds[toggleKey] ~= loopId or (sv.money.Value or 0) < item.Price then break end
                local beforeStock = getShopStockCount(c, item.Name)
                if beforeStock <= 0 then break end
                if purchaseShopItem(c, item.Name) then
                    waitShopStockChange(c, item.Name, beforeStock, 1.25)
                else
                    task.wait(0.5)
                end
            end
        end
        task.wait(allStock and 1 or 5)
    end
end
function startBuyShopLoop(c, toggleKey, allStock)
    shopBuyLoopIds[toggleKey] = (shopBuyLoopIds[toggleKey] or 0) + 1
    local loopId = shopBuyLoopIds[toggleKey]
    task.spawn(buyShopLoop, c, toggleKey, allStock, loopId)
end

