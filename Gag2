local TRADE_MAX_ENTRIES = 20
local mailboxRuntime = { Sending = false }

function getMailInventory()
    local replica = modules.playerstateclient:GetLocalReplica()
    return replica and replica.Data and replica.Data.Inventory or {}
end
function getBackpackFruitMailData()
    local data = {}
    for _, container in ipairs({ sv.plr.Character, sv.plr:FindFirstChild("Backpack") }) do
        if container then
            for _, obj in ipairs(container:GetChildren()) do
                if isInventoryFruitObject(obj) then
                    local key = tostring(obj:GetAttribute("Id") or obj:GetAttribute("FruitId") or obj.Name)
                    local name = getInventoryFruitName(obj) or cleanName(obj.Name)
                    if key ~= "" and name and name ~= "" then
                        data[key] = { FruitName = name, Name = name, Count = 1, Instance = obj }
                    end
                end
            end
        end
    end
    return data
end
function getMailCategoryData(category)
    local inv = getMailInventory()
    local data = inv[category]
    if category == "HarvestedFruits" then
        if type(data) ~= "table" or next(data) == nil then
            if type(inv.Fruits) == "table" and next(inv.Fruits) ~= nil then
                data = inv.Fruits
            elseif type(inv.Fruit) == "table" and next(inv.Fruit) ~= nil then
                data = inv.Fruit
            else
                data = getBackpackFruitMailData()
            end
        end
    end
    return type(data) == "table" and data or {}
end
function getMailItemCount(category, key)
    local data = getMailCategoryData(category)[key]
    if category == "Pets" or category == "HarvestedFruits" then
        return data and 1 or 0
    end
    return tonumber(data) or 0
end
function buildSendAllMailRaw()
    local raw = {}
    for _, category in ipairs(mailCategories) do
        local data = getMailCategoryData(category)
        if type(data) == "table" then
            for key in pairs(data) do
                local itemCount = getMailItemCount(category, key)
                if itemCount > 0 then
                    local sendCount = (category == "Pets" or category == "HarvestedFruits") and 1 or itemCount
                    table.insert(raw, { Category = category, Key = key, Count = sendCount })
                end
            end
        end
    end
    return raw
end
function buildMailboxQueue(mode)
    if mode == "All Inventory" then return buildSendAllMailRaw() end
    return {}
end
function buildMailboxTradeItems(mode)
    local tradeItems = {}
    for _, item in ipairs(buildMailboxQueue(mode)) do
        local key = item.Key or item.ItemKey
        local available = getMailItemCount(item.Category, key)
        local count = mode == "All Inventory" and available or math.min(item.Count or st.mailAmount or 1, available)
        if key and count > 0 then
            tradeItems[#tradeItems + 1] = { Category = item.Category, ItemKey = key, Count = count }
        end
    end
    return tradeItems
end
function tradeBuildBatches(items)
    local batches, cur = {}, {}
    for _, it in ipairs(items) do
        if (it.Count or 0) > 0 then
            cur[#cur + 1] = { Category = it.Category, ItemKey = it.ItemKey, Count = it.Count }
            if #cur >= TRADE_MAX_ENTRIES then batches[#batches + 1] = cur cur = {} end
        end
    end
    if #cur > 0 then batches[#batches + 1] = cur end
    return batches
end
function getMailboxUserId()
    local username = tostring(st.mailUsername or ""):gsub("^%s+", ""):gsub("%s+$", "")
    if username == "" then return nil end
    local mailbox = modules.networking and modules.networking.Mailbox
    if not mailbox or not mailbox.LookupPlayer then return nil end
    local ok, userId = pcall(function() return mailbox.LookupPlayer:Fire(username) end)
    return ok and userId or nil
end

local MAILBOX_BATCH_RETRIES = 3
local MAILBOX_RETRY_DELAY = 21
local MAILBOX_MIN_BATCH_DELAY = 20
function sendMailboxOnce(mode)
    if mailboxRuntime.Sending then return false end
    local mailbox = modules.networking and modules.networking.Mailbox
    if not mailbox or not mailbox.SendBatch then return false end
    local userId = getMailboxUserId()
    if not userId then return false end
    mode = mode or st.mailMode

    local tradeItems = buildMailboxTradeItems(mode)
    if #tradeItems == 0 then return false end

    mailboxRuntime.Sending = true
    local sentAny = false
    local ok, err = pcall(function()
        local batches = tradeBuildBatches(tradeItems)
        local batchDelay = math.max(MAILBOX_MIN_BATCH_DELAY, tonumber(st.mailDelay) or 1)
        for index, batch in ipairs(batches) do
            local batchSent = false
            for attempt = 1, MAILBOX_BATCH_RETRIES do
                local okFire, result = pcall(function()
                    return mailbox.SendBatch:Fire(userId, batch, tostring(st.mailNote or ""))
                end)
                if okFire and result ~= false then batchSent = true break end
                if attempt < MAILBOX_BATCH_RETRIES then task.wait(MAILBOX_RETRY_DELAY) end
            end
            if batchSent then sentAny = true elseif not sentAny then break end
            if index < #batches then task.wait(batchDelay) end
        end
    end)
    mailboxRuntime.Sending = false
    if not ok then warn("[NoUI] Mailbox send error: " .. tostring(err)) end
    return sentAny
end

