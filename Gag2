local seedRarityByName = {}
local function normalizeSeedLookupName(name)
    return tostring(name or "")
        :gsub("%b[]", "")
        :gsub("%s+x%d+$", "")
        :gsub("^%s+", "")
        :gsub("%s+$", "")
        :lower()
end

function getSeedRarity(seedName)
    if seedName == nil then return nil end
    local normalized = normalizeSeedLookupName(seedName)
    local rarity = seedRarityByName[normalized]
    if rarity then return rarity end
    for _, data in ipairs(modules.seeddata) do
        if normalizeSeedLookupName(data.SeedName) == normalized then
            seedRarityByName[normalized] = data.Rarity
            return data.Rarity
        end
    end
    return nil
end

function getSeedPrice(seedName)
    for _, data in ipairs(modules.seeddata) do
        if data.SeedName == seedName then
            return data.PurchasePrice or 0
        end
    end
    return 0
end

local gearPriceCache = nil
function getGearPrice(itemName)
    if not gearPriceCache then
        gearPriceCache = {}
        local ok, mod = pcall(function() return require(sv.r.SharedModules.GearShopData) end)
        local data = ok and type(mod) == "table" and (mod.Data or mod) or {}
        for _, d in ipairs(data) do
            local nm = d.ItemName or d.GearName or d.Name
            if nm then gearPriceCache[nm] = tonumber(d.Cost or d.PurchasePrice or d.Price) or 0 end
        end
    end
    return gearPriceCache[itemName] or 0
end

local packetNames = {
    purchaseseed = { "PurchaseSeed", "BuySeed" },
    purchasegear = { "PurchaseGear", "BuyGear" },
    sellall      = { "SellAll", "SellInventory" },
}
local packetCache = {}
function getPacketIdByNames(names)
    local cacheKey = table.concat(names, "|")
    if packetCache[cacheKey] then return packetCache[cacheKey] end
    for _, name in ipairs(names) do
        local id = remote:GetAttribute(name)
        if type(id) == "number" then packetCache[cacheKey] = id return id end
    end
    for attr, id in pairs(remote:GetAttributes()) do
        if type(id) == "number" then
            for _, name in ipairs(names) do
                if string.lower(attr):find(string.lower(name)) then
                    packetCache[cacheKey] = id
                    return id
                end
            end
        end
    end
end
function packetIdToString(id)
    return string.char(id % 256) .. string.char(math.floor(id / 256))
end
function firePacketByName(key, ...)
    local names = packetNames[key]
    if not names then return false end
    local id = getPacketIdByNames(names)
    if not id then return false end
    local payload = packetIdToString(id)
    for _, v in ipairs({ ... }) do
        if type(v) == "string" then
            payload ..= string.char(#v) .. v
        elseif type(v) == "number" then
            payload ..= string.char(v)
        end
    end
    remote:FireServer(buffer.fromstring(payload))
    return true
end

function cleanName(text)
    return text:match("^(.-) %(") or text
end

