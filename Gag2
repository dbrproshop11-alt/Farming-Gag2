function getFruitInventory()
    local current = sv.plr:GetAttribute("FruitCount") or 0
    local max = sv.plr:GetAttribute("MaxFruitCapacity") or 100
    return current, max
end

function getInventoryFruitId(obj)
    return obj and (
        obj:GetAttribute("Id") or obj:GetAttribute("FruitId") or obj:GetAttribute("FruitID")
        or obj:GetAttribute("FruitUUID") or obj:GetAttribute("UUID"))
end
function getInventoryFruitName(obj)
    return obj:GetAttribute("FruitName") or obj:GetAttribute("Fruit")
        or tostring(obj.Name or ""):match("^(.-)%s*%[") or tostring(obj.Name or "")
end
function isInventoryFruitObject(obj)
    if not obj or not (obj:IsA("Tool") or obj:IsA("Configuration")) then return false end
    if obj:GetAttribute("HarvestedFruit") == true or obj:GetAttribute("FruitProxy") == true then return true end
    return getInventoryFruitId(obj) ~= nil and getInventoryFruitName(obj) ~= nil
end
function getHarvestBackpackCount()
    local current = tonumber(select(1, getFruitInventory())) or 0
    local count = 0
    for _, container in ipairs({ sv.plr:FindFirstChild("Backpack"), sv.plr.Character }) do
        if container then
            for _, obj in ipairs(container:GetChildren()) do
                if isInventoryFruitObject(obj) then count += 1 end
            end
        end
    end
    return math.max(current, count)
end

function getDoubleNothingNPCS()
    return modules and modules.networking and modules.networking.NPCS
end
function fruitInventoryMaxed()
    local current = tonumber(getFruitInventory()) or 0
    current = math.max(current, getHarvestBackpackCount())
    local max = sv.plr:GetAttribute("MaxFruitCapacity") or 100
    return max > 0 and current >= max
end
function dailyDealAvailable()
    local npcs = getDoubleNothingNPCS()
    if not (npcs and npcs.CheckDailyDeal) then return false end
    local ok, result = pcall(function() return npcs.CheckDailyDeal:Fire() end)
    if not ok then return false end
    if type(result) == "table" then
        if result.Available ~= nil then return result.Available == true end
        if result.TimeRemaining ~= nil then return (tonumber(result.TimeRemaining) or math.huge) <= 0 end
    end
    return result == true
end
function sellDailyDealAll()
    local npcs = getDoubleNothingNPCS()
    if not (npcs and npcs.UseDailyDealAll) then return false end
    local ok, result = pcall(function() return npcs.UseDailyDealAll:Fire() end)
    if not ok then return false end
    if type(result) == "table" and result.Success == false then return false end
    return result ~= false
end
function dailyDealThresholdReached()
    if st.dailyDealMode == "Count" then
        local current = math.max(tonumber(getFruitInventory()) or 0, getHarvestBackpackCount())
        return current >= math.max(1, math.floor(tonumber(st.dailyDealCount) or 1))
    end
    return fruitInventoryMaxed()
end
function sellAll()
    firePacketByName("sellall", 25)
end
function runSellCycle()
    if st.useDailyDealSell then
        if dailyDealAvailable() then
            if dailyDealThresholdReached() then
                if sellDailyDealAll() then return end
            end
            return
        end
    end
    sellAll()
end

